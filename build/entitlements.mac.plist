<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <!-- Required so the hardened runtime lets CoreLocation deliver the location
         authorization prompt. Without it, locationd logs "Client has supported the
         hardened runtime but doesn't have the entitlement, not sending #AuthPrompt"
         and no prompt ever appears (verified from a live locationd capture). -->
    <key>com.apple.security.personal-information.location</key>
    <true/>
    <!-- Required so the hardened runtime lets AVFoundation DELIVER camera/mic
         frames. Without these, the exact same failure mode as location above:
         getUserMedia resolves and the MediaStreamTrack reports readyState "live",
         but macOS silently delivers ZERO frames — the <video> stays 0x0/readyState 0
         and MediaStreamTrackProcessor emits no frame (verified live on the packaged
         build). The NSCamera/NSMicrophoneUsageDescription strings (Info.plist, see
         electron-builder.yml extendInfo) are NOT enough on a hardened runtime; the
         entitlement is the missing half. -->
    <key>com.apple.security.device.camera</key>
    <true/>
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <!-- WebAuthn Touch ID platform authenticator: app.configureWebAuthn stores
         credentials under this keychain access group (see src/main/webauthn.ts).
         AMFI-restricted → only valid because build/embedded.provisionprofile (minted
         from the free personal team ZMKDR6H89Y) authorizes this exact group. The
         group MUST match WEBAUTHN_KEYCHAIN_GROUP in webauthn.ts. -->
    <key>keychain-access-groups</key>
    <array>
      <string>ZMKDR6H89Y.com.mickaelfm.mira.webauthn</string>
    </array>
    <!-- keychain-access-groups is only HONORED at runtime when the process also
         carries application-identifier (+ team-identifier): macOS validates the
         keychain group's team prefix against it. Xcode adds these automatically;
         electron-builder does not, so without them Chromium's FIDO layer reports
         "keychain-access-group entitlement is missing or incorrect" and the Touch ID
         create()/get() hangs with no prompt (verified 2026-07-22). Both are
         AMFI-restricted but authorized by build/embedded.provisionprofile
         (application-identifier ZMKDR6H89Y.com.mickaelfm.mira, team ZMKDR6H89Y). MAIN
         ONLY — the profile-less helpers must not carry them (see the inherit plist). -->
    <key>com.apple.application-identifier</key>
    <string>ZMKDR6H89Y.com.mickaelfm.mira</string>
    <key>com.apple.developer.team-identifier</key>
    <string>ZMKDR6H89Y</string>
  </dict>
</plist>
